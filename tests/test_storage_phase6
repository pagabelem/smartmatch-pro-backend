class TestValidateFile:
    def test_valid_pdf(self, storage_svc):
        storage_svc.validate_file("cv.pdf", 1024)  # doit passer sans exception

    def test_invalid_extension(self, storage_svc):
        from app.core.exceptions import ValidationException
        with pytest.raises(ValidationException, match="Extension"):
            storage_svc.validate_file("cv.exe", 1024)

    def test_file_too_large(self, storage_svc):
        from app.core.exceptions import ValidationException
        with pytest.raises(ValidationException, match="volumineux"):
            storage_svc.validate_file("cv.pdf", 10 * 1024 * 1024)  # 10 Mo > 2 Mo

    def test_valid_docx(self, storage_svc):
        storage_svc.validate_file("rapport.docx", 500_000)

    def test_extension_case_insensitive(self, storage_svc):
        storage_svc.validate_file("CV.PDF", 1024)  # doit passer


