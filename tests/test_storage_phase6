class TestSaveFile:
    @pytest.mark.asyncio
    async def test_save_creates_file(self, storage_svc, tmp_path):
        upload = make_upload_file("test.pdf", b"PDF content")
        relative_path = await storage_svc.save_file(upload, subfolder="uploads/resumes/42")

        absolute = tmp_path / relative_path
        assert absolute.exists()
        assert absolute.read_bytes() == b"PDF content"

    @pytest.mark.asyncio
    async def test_save_returns_relative_path(self, storage_svc):
        upload = make_upload_file("cv.pdf", b"data")
        relative_path = await storage_svc.save_file(upload, subfolder="uploads/resumes/1")
        assert relative_path.startswith("uploads/resumes/1/")
        assert relative_path.endswith(".pdf")

    @pytest.mark.asyncio
    async def test_save_with_custom_filename(self, storage_svc, tmp_path):
        upload = make_upload_file("original.pdf", b"data")
        relative_path = await storage_svc.save_file(
            upload, subfolder="uploads/resumes/5", custom_filename="mon_cv"
        )
        assert "mon_cv" in relative_path

    @pytest.mark.asyncio
    async def test_save_invalid_extension_raises(self, storage_svc):
        from app.core.exceptions import ValidationException
        upload = make_upload_file("virus.exe", b"data")
        with pytest.raises(ValidationException):
            await storage_svc.save_file(upload, subfolder="uploads/resumes/1")

    @pytest.mark.asyncio
    async def test_save_creates_subdirectory(self, storage_svc, tmp_path):
        upload = make_upload_file("cv.pdf", b"data")
        await storage_svc.save_file(upload, subfolder="uploads/resumes/99")
        assert (tmp_path / "uploads" / "resumes" / "99").is_dir()


