class TestStorageRoutes:
    
    def test_serve_file_owner_access(self, client, test_profile, test_user, tmp_path):
        """Le propriétaire peut accéder à son propre fichier."""
        from app.core.security import create_access_token_with_expires
        
        # Créer le token pour test_user
        token = create_access_token_with_expires(data={"sub": str(test_user.id)})
        
        # Créer le fichier physiquement dans storage/
        import os
        from app.config import settings
        
        storage_dir = Path(settings.STORAGE_DIR) if hasattr(settings, 'STORAGE_DIR') else Path("storage")
        file_dir = storage_dir / "uploads" / "resumes" / str(test_profile.id)
        file_dir.mkdir(parents=True, exist_ok=True)
        (file_dir / "cv.pdf").write_bytes(b"%PDF-1.4 fake")
        
        response = client.get(
            f"/api/v1/storage/uploads/resumes/{test_profile.id}/cv.pdf",
            headers={"Authorization": f"Bearer {token}"},
        )
        # Le fichier existe peut-être ou non selon le storage_dir réel
        assert response.status_code in [200, 404]

    def test_serve_file_other_user_forbidden(self, client, test_profile, test_second_user):
        """Un autre utilisateur reçoit 403."""
        from app.core.security import create_access_token_with_expires
        
        token = create_access_token_with_expires(data={"sub": str(test_second_user.id)})
        
        response = client.get(
            f"/api/v1/storage/uploads/resumes/{test_profile.id}/cv.pdf",
            headers={"Authorization": f"Bearer {token}"},
        )
        # Soit 403 (fichier existe mais accès refusé) soit 404 (fichier inexistant)
        assert response.status_code in [403, 404]

    def test_serve_file_admin_access(self, client, test_profile, test_admin):
        """L'admin accède à tous les fichiers."""
        from app.core.security import create_access_token_with_expires
        
        token = create_access_token_with_expires(data={"sub": str(test_admin.id)})
        
        response = client.get(
            f"/api/v1/storage/uploads/resumes/{test_profile.id}/cv.pdf",
            headers={"Authorization": f"Bearer {token}"},
        )
        # L'admin a accès même si le fichier n'existe pas (404) ou existe (200)
        assert response.status_code in [200, 404]

    def test_delete_file_admin_only(self, client, test_admin, tmp_path):
        """Seul l'admin peut supprimer un fichier."""
        from app.core.security import create_access_token_with_expires
        
        token = create_access_token_with_expires(data={"sub": str(test_admin.id)})
        
        response = client.delete(
            "/api/v1/storage/uploads/tmp/test.pdf",
            headers={"Authorization": f"Bearer {token}"},
        )
        # Le fichier n'existe pas, donc 404
        assert response.status_code == 404

    def test_delete_file_non_admin_forbidden(self, client, test_user):
        """Un utilisateur normal ne peut pas supprimer."""
        from app.core.security import create_access_token_with_expires
        
        token = create_access_token_with_expires(data={"sub": str(test_user.id)})
        
        response = client.delete(
            "/api/v1/storage/uploads/tmp/test.pdf",
            headers={"Authorization": f"Bearer {token}"},
        )
        # Non admin = 403
        assert response.status_code == 403

    def test_serve_nonexistent_file_404(self, client, test_admin):
        from app.core.security import create_access_token_with_expires
        
        token = create_access_token_with_expires(data={"sub": str(test_admin.id)})
        
        response = client.get(
            "/api/v1/storage/uploads/resumes/999/ghost.pdf",
            headers={"Authorization": f"Bearer {token}"},
        )
        assert response.status_code == 404

    def test_unauthenticated_access_401(self, client):
        response = client.get("/api/v1/storage/uploads/resumes/1/cv.pdf")
        assert response.status_code == 401