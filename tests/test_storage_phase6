@pytest.fixture
def storage_svc(tmp_path):
    """Instance StorageService avec dossier temporaire."""
    from app.modules.storage.storage_service import StorageService
    return StorageService(
        base_dir=tmp_path,
        allowed_extensions={".pdf", ".docx", ".png"},
        max_size=2 * 1024 * 1024,  # 2 Mo
    )


def make_upload_file(filename: str, content: bytes = b"fake content") -> UploadFile:
    """Helper : crée un UploadFile simulé."""
    file = UploadFile(
        filename=filename,
        file=io.BytesIO(content),
    )
    file.size = len(content)
    return file


