# ── Copy this file to .env and fill in your values ────────────────────────────
# NEVER commit .env to git — it is in .gitignore

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=SmartMatch Pro
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── Database — PostgreSQL ─────────────────────────────────────────────────────
#
# OPTION A — Full URL (recommended for managed DBs: Railway, Supabase, Render…)
#   Uncomment and fill in:
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/db_pro
#
# OPTION B — Individual fields (auto-assembled at startup)
#   Leave DATABASE_URL empty (or commented out) and fill these in:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=smartmatch
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=smartmatch_db
#
# Connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=f1d7c8d8b8c9b11d14ee7166435a028a87584ac290e216f2f1dfe7ceefd61974
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=app/storage/uploads
MAX_FILE_SIZE_MB=5
ALLOWED_RESUME_EXTENSIONS=pdf,docx

# ── NLP ───────────────────────────────────────────────────────────────────────
SPACY_MODEL_FR=fr_core_news_md
SPACY_MODEL_EN=en_core_web_md

# ── OpenAI (optional — AI modules V2/V3) ─────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
